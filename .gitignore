# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# test coverage (local / CI artifact)
coverage/

# generated native folders
/ios
/android

# Root markdown — only README.md and CHANGELOG.md may be pushed (docs/ and nested *.md stay trackable)
/*.md
!/README.md
!/CHANGELOG.md

# Client feedback working folder (local only — do not push)
z-feedback_cliente/

# .png files (screenshots/docs at repo root); keep app icons for EAS prebuild
*.png
!assets/images/
!assets/images/**

# Legacy TMS sample (removed — use TMS_fusion)
PROYECTO_MUESTRA/
