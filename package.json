{
  "name": "pp2-mobile",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "check:secrets": "node scripts/check-client-secrets.mjs",
    "check:daily-reports": "node scripts/check-daily-reports-order.mjs",
    "sync:client-mirror": "node scripts/sync-client-mirror.mjs",
    "ci": "npm run lint && npm run check:secrets && npm run check:daily-reports && npm test -- --ci --coverage --maxWorkers=2",
    "qa:5.6": "node scripts/qa-preflight-5-6.mjs",
    "qa:6.4": "node scripts/qa-preflight-6-4.mjs",
    "qa:7.1": "node scripts/qa-preflight-7-1.mjs",
    "build:preflight": "node scripts/eas-build-preflight-7-2.mjs",
    "eas:push-env": "node scripts/eas-push-env-from-local.mjs",
    "smoke:5.7": "node scripts/smoke-5-7.mjs",
    "db:apply-rls": "node scripts/apply-supabase-migration.mjs",
    "db:apply-wt20": "node scripts/apply-wt20-wait-time.mjs",
    "db:seed-driver-test": "node scripts/create-driver-test-user.mjs",
    "db:assign-driver-test-loads": "node scripts/assign-loads-driver-test.mjs",
    "db:assign-driver-test-loads:pagination": "node scripts/assign-loads-driver-test.mjs --max=21",
    "db:trim-driver-test-loads": "node scripts/trim-driver-test-loads.mjs",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
