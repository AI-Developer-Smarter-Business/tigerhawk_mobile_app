# Copiar a .env.local y completar valores reales.
# Solo claves PÚBLICAS en el repo móvil. Nunca commitear secretos.

# Expo (app móvil)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_TMS_API_URL=http://localhost:3000

# Opcional: mismas variables con prefijo Next si compartes .env con el TMS
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_APP_URL=

# NO incluir en la app móvil:
# SUPABASE_SERVICE_ROLE_KEY
# PORT_HOUSTON_CLIENT_SECRET
# RESEND_API_KEY
