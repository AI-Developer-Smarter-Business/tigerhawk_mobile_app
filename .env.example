# Copy to .env.local and fill real values. Public keys only in repo — never commit secrets.

# --- Mobile (Expo) — required ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# TMS Next.js base URL (all /api/mobile/* traffic).
# Until Ian merges the 14 Jul mobile branch to main, point at the Netlify/Vercel
# *preview* deploy that hosts auth/login, driver/loads, accept, pod-signature.
# Verify with: npm run smoke:a0 -- --require-preview
# Docs: docs/A0_MOBILE_API_PREVIEW_SMOKE.md
# Production (post-merge): https://tigerhawkv2.netlify.app (or tms.tigerhawklogistics.com)
# Local: http://localhost:3000 or http://YOUR_PC_IP:3000 on physical phone
EXPO_PUBLIC_TMS_API_URL=https://tigerhawkv2.netlify.app

# Optional — Account “Contact dispatch” Call / Email actions (J.5). Guidance still shows without these.
# EXPO_PUBLIC_DISPATCH_PHONE=+17135551212
# EXPO_PUBLIC_DISPATCH_EMAIL=dispatch@example.com

# Phase A wait-time demo (WT.3): in-memory timer, no TMS wait-time API calls.
# EXPO_PUBLIC_WAIT_TIME_MOCK=1

# --- Shared with TMS (optional in mobile .env.local; required in TMS .env.local) ---
# Same Supabase project as TMS (URL + anon key must match).
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# NO incluir en la app móvil:
# SUPABASE_SERVICE_ROLE_KEY
# PORT_HOUSTON_CLIENT_SECRET
# RESEND_API_KEY
