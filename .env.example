# Copy to .env.local and fill real values. Public keys only in repo — never commit secrets.

# --- Mobile (Expo) — required ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# TMS Next.js base URL (upload BFF: /api/mobile/loads/{id}/documents).
# Staging Netlify: https://tigerhawk.netlify.app
# Production: https://tms.tigerhawklogistics.com
# Local: http://localhost:3000 or http://YOUR_PC_IP:3000 on physical phone
EXPO_PUBLIC_TMS_API_URL=https://tigerhawk.netlify.app

# Phase A wait-time demo (WT.3): in-memory timer, no TMS wait-time API calls.
# EXPO_PUBLIC_WAIT_TIME_MOCK=1

# --- Shared with TMS (optional in mobile .env.local; required in TMS .env.local) ---
# Same Supabase project as TMS (URL + anon key must match).
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# NO incluir en la app móvil:
# SUPABASE_SERVICE_ROLE_KEY
# PORT_HOUSTON_CLIENT_SECRET
# RESEND_API_KEY
