{
  "expo": {
    "name": "Tigerhawk Mobile",
    "slug": "pp2",
    "version": "0.1.2",
    "orientation": "portrait",
    "icon": "./assets/images/logo_new.png",
    "scheme": "pp2",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo_new.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1120"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tigerhawk.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Tigerhawk Mobile uses your location while the app is open so you can share your position with dispatch for assigned loads.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tigerhawk.mobile",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo_new.png",
        "backgroundColor": "#0B1120"
      },
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "pp2",
              "pathPrefix": "/auth/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo_new.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Tigerhawk Mobile needs access to your photos to upload proof of delivery.",
          "cameraPermission": "Tigerhawk Mobile needs the camera to capture proof of delivery."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Tigerhawk Mobile uses your location while the app is open so you can share your position with dispatch for assigned loads.",
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": false
        }
      ],
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_new.png",
          "resizeMode": "contain",
          "backgroundColor": "#0B1120",
          "imageWidth": 280
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "711ff937-bac6-440a-b680-d15285b697aa"
      }
    },
    "owner": "likaon1606"
  }
}
